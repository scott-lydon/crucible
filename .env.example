# Copy to .env (which is gitignored). Local defaults match docker-compose.yml.

# Host port the local Postgres container publishes. Default 5432; set to a
# free port (for example 5434) if this machine already runs Postgres on 5432.
CRUCIBLE_DB_PORT=5432

# Primary database the app reads and Alembic migrates. Match the port above.
DATABASE_URL=postgresql+asyncpg://crucible:crucible@localhost:5432/crucible

# Database the integration test suite creates and migrates (read by tests/conftest.py).
CRUCIBLE_TEST_DATABASE_URL=postgresql+asyncpg://crucible:crucible@localhost:5432/crucible_test

# Needed from slice 5 (oracles) onward. Leave blank until then.
ANTHROPIC_API_KEY=

# Verifier recall below this halts certification (US-13).
HALT_RECALL_THRESHOLD=0.7

# When true, the Anthropic client returns fixture responses and the run header
# shows a mock banner so it can never be mistaken for a real run (US-15).
MOCK_LLM=false
